# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ─────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data Files ───────────────────────────────────────────────────────────────
