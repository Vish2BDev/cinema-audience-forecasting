/models/
*.pkl
*.pickle
*.joblib
*.cbm
model_lgb.txt
model_xgb.json
*.model

# ── Submissions & Outputs ────────────────────────────────────────────────────
submission*.csv
outputs/

# ── Logs & Run Artifacts ─────────────────────────────────────────────────────
*.log
run_log.txt
logs/

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
*.code-workspace

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Miscellaneous ────────────────────────────────────────────────────────────
.cache/
tmp/
temp/
scratch/
